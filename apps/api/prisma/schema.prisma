generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum MarketplaceKey {
  AWIN
  SHOPEE
  MERCADO_LIVRE
  MAGALU
  MANUAL
}

enum IntegrationType {
  API
  FEED
  MANUAL
  ASSISTED
}

enum OfferStatus {
  DRAFT
  VALIDATING
  VALID
  INVALID
  EXPIRED
  AFFILIATE_LINK_MISSING
  SCHEDULED
  PUBLISHED
  FAILED
  PAUSED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum Channel {
  TELEGRAM
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  MANUAL
}

enum ScheduledPostStatus {
  SCHEDULED
  READY_TO_SEND
  PUBLISHED
  FAILED
  CANCELED
}

enum WhatsAppProvider {
  WPPCONNECT
  CLOUD_API
  WASSENGER
  WEBHOOK
  ASSISTED
}

enum WhatsAppConnectionStatus {
  CONNECTED
  DISCONNECTED
  WAITING_QR_CODE
  EXPIRED
  AUTH_ERROR
  ERROR
  WARNING
}

model User {
  id                String             @id @default(uuid())
  name              String             @db.VarChar(150)
  email             String             @unique @db.VarChar(180)
  passwordHash      String
  role              Role               @default(ADMIN)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  generatedContents GeneratedContent[]
  auditLogs         AuditLog[]
}

model Marketplace {
  id               String             @id @default(uuid())
  name             String             @db.VarChar(100)
  key              MarketplaceKey     @unique
  integrationType  IntegrationType
  baseUrl          String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  affiliateAccounts AffiliateAccount[]
  products         Product[]
  offers           Offer[]
  campaigns        Campaign[]
  integrationLogs  IntegrationLog[]
  priceHistory     PriceHistory[]
  coupons          Coupon[]
  seoPages         SeoPage[]
}

model AffiliateAccount {
  id                   String      @id @default(uuid())
  marketplaceId        String
  marketplace          Marketplace @relation(fields: [marketplaceId], references: [id])
  name                 String      @db.VarChar(120)
  accountIdentifier    String?     @db.VarChar(180)
  affiliateTag         String?     @db.VarChar(180)
  encryptedCredentials Json?
  config               Json?
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?
}

model Product {
  id                String             @id @default(uuid())
  marketplaceId     String
  marketplace       Marketplace        @relation(fields: [marketplaceId], references: [id])
  categoryId        String?
  categoryRef       Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId           String?
  brandRef          Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  externalId        String?            @db.VarChar(180)
  title             String
  description       String?
  imageUrl          String?
  productUrl        String
  brand             String?            @db.VarChar(120)
  category          String?            @db.VarChar(120)
  rating            Decimal?           @db.Decimal(3, 2)
  reviewCount       Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  offers            Offer[]
  generatedContents GeneratedContent[]
  priceHistory      PriceHistory[]
  offerScores       OfferScore[]
  couponProducts    CouponProduct[]
  seoPages          SeoPage[]
  opportunities     ProductOpportunity[]
  publicationSchedules PublicationSchedule[]
  creativeAssets    CreativeAsset[]

  @@index([marketplaceId])
  @@index([categoryId])
  @@index([brandId])
  @@index([externalId])
  @@index([deletedAt])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(140)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  products    Product[]
  couponCategories CouponCategory[]
  seoPages    SeoPage[]

  @@index([isActive])
  @@index([deletedAt])
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(140)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  products    Product[]

  @@index([isActive])
  @@index([deletedAt])
}

model Offer {
  id                  String      @id @default(uuid())
  productId           String
  product             Product     @relation(fields: [productId], references: [id])
  marketplaceId       String
  marketplace         Marketplace @relation(fields: [marketplaceId], references: [id])
  originalUrl         String
  affiliateUrl        String?
  currentPrice        Decimal?    @db.Decimal(12, 2)
  oldPrice            Decimal?    @db.Decimal(12, 2)
  discountPercent     Decimal?    @db.Decimal(5, 2)
  couponCode          String?     @db.VarChar(120)
  couponDescription   String?
  freeShipping        Boolean?
  estimatedCommission Decimal?    @db.Decimal(12, 2)
  commissionPercent   Decimal?    @db.Decimal(5, 2)
  score               Decimal?    @db.Decimal(5, 2)
  status              OfferStatus @default(DRAFT)
  validUntil          DateTime?
  metadata            Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  scheduledPosts      ScheduledPost[]
  publishLogs         PublishLog[]
  shortLinks          ShortLink[]
  clickEvents         ClickEvent[]
  generatedContents   GeneratedContent[]
  publicationSchedules PublicationSchedule[]

  @@index([marketplaceId])
  @@index([status])
  @@index([createdAt])
}

model GeneratedContent {
  id          String    @id @default(uuid())
  offerId     String?
  offer       Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  channel     Channel   @default(WHATSAPP)
  title       String    @db.VarChar(180)
  prompt      String?
  content     String
  tone        String?   @db.VarChar(80)
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([offerId])
  @@index([productId])
  @@index([createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String   @db.VarChar(80)
  entityId  String?
  action    String   @db.VarChar(80)
  before    Json?
  after     Json?
  metadata  Json?
  ipHash    String?  @db.VarChar(120)
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model MessageTemplate {
  id         String     @id @default(uuid())
  name       String     @db.VarChar(120)
  channel    Channel
  content    String
  isDefault  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  campaigns  Campaign[]
}

model Campaign {
  id                    String         @id @default(uuid())
  name                  String         @db.VarChar(150)
  marketplaceId         String?
  marketplace           Marketplace?   @relation(fields: [marketplaceId], references: [id])
  templateId            String?
  template              MessageTemplate? @relation(fields: [templateId], references: [id])
  channel               Channel
  status                CampaignStatus @default(PAUSED)
  startTime             String?
  endTime               String?
  intervalMinutes       Int            @default(30)
  dailyLimit            Int            @default(30)
  requireManualApproval Boolean        @default(true)
  allowRepost           Boolean        @default(false)
  minHoursToRepost      Int            @default(72)
  config                Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  scheduledPosts        ScheduledPost[]
  whatsappGroups        CampaignWhatsAppGroup[]
  messageSendLogs       MessageSendLog[]
}

model ScheduledPost {
  id            String              @id @default(uuid())
  campaignId    String?
  campaign      Campaign?           @relation(fields: [campaignId], references: [id])
  offerId       String
  offer         Offer               @relation(fields: [offerId], references: [id])
  whatsappGroupId String?
  whatsappGroup WhatsAppGroup?      @relation(fields: [whatsappGroupId], references: [id])
  channel       Channel
  message       String
  scheduledAt   DateTime
  publishedAt   DateTime?
  status        ScheduledPostStatus @default(SCHEDULED)
  errorMessage  String?
  retryCount    Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  publishLogs   PublishLog[]
  messageSendLogs MessageSendLog[]
  publicationSchedule PublicationSchedule?

  @@index([status, scheduledAt])
  @@index([whatsappGroupId])
}

model WhatsAppConnection {
  id                   String                  @id @default(uuid())
  name                 String                  @db.VarChar(120)
  sessionName          String?                 @unique @db.VarChar(120)
  phoneNumber          String?                 @db.VarChar(40)
  provider             WhatsAppProvider        @default(WPPCONNECT)
  status               WhatsAppConnectionStatus @default(DISCONNECTED)
  phoneNumberId        String?                 @db.VarChar(120)
  qrCode               String?
  lastConnectedAt      DateTime?
  lastError            String?
  consecutiveFailures  Int                     @default(0)
  dailySentCount       Int                     @default(0)
  dailyLimit           Int                     @default(100)
  dailyWindowStartedAt DateTime?
  minIntervalSeconds   Int                     @default(60)
  lastSentAt           DateTime?
  encryptedCredentials Json?
  config               Json?
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  groups               WhatsAppGroup[]
  messageSendLogs      MessageSendLog[]
}

model WhatsAppGroup {
  id           String                  @id @default(uuid())
  connectionId String
  connection   WhatsAppConnection      @relation(fields: [connectionId], references: [id])
  name         String                  @db.VarChar(160)
  externalId   String                  @db.VarChar(220)
  description  String?
  category     String?                 @db.VarChar(120)
  type         String                  @default("GROUP") @db.VarChar(40)
  isActive     Boolean                 @default(true)
  minIntervalSeconds Int               @default(60)
  dailyLimit   Int                     @default(100)
  dailySentCount Int                   @default(0)
  dailyWindowStartedAt DateTime?
  lastSentAt   DateTime?
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  campaigns    CampaignWhatsAppGroup[]
  scheduledPosts ScheduledPost[]
  messageSendLogs MessageSendLog[]

  @@index([connectionId])
  @@unique([connectionId, externalId])
}

model CampaignWhatsAppGroup {
  campaignId String
  campaign   Campaign      @relation(fields: [campaignId], references: [id])
  groupId    String
  group      WhatsAppGroup @relation(fields: [groupId], references: [id])
  createdAt  DateTime      @default(now())

  @@id([campaignId, groupId])
  @@index([groupId])
}

model PublishLog {
  id              String         @id @default(uuid())
  scheduledPostId String?
  scheduledPost   ScheduledPost? @relation(fields: [scheduledPostId], references: [id])
  offerId         String?
  offer           Offer?         @relation(fields: [offerId], references: [id])
  channel         Channel
  status          String         @db.VarChar(50)
  providerResponse Json?
  errorMessage    String?
  createdAt       DateTime       @default(now())
}

model MessageSendLog {
  id                  String              @id @default(uuid())
  scheduledPostId     String?
  scheduledPost       ScheduledPost?      @relation(fields: [scheduledPostId], references: [id])
  campaignId          String?
  campaign            Campaign?           @relation(fields: [campaignId], references: [id])
  whatsappGroupId     String?
  whatsappGroup       WhatsAppGroup?      @relation(fields: [whatsappGroupId], references: [id])
  whatsappConnectionId String?
  whatsappConnection  WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  message             String
  scheduledAt         DateTime?
  sentAt              DateTime?
  status              String              @db.VarChar(40)
  errorMessage        String?
  attempts            Int                 @default(0)
  providerResponse    Json?
  userResponsible     String?             @db.VarChar(180)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([campaignId])
  @@index([whatsappGroupId])
  @@index([whatsappConnectionId])
  @@index([status, scheduledAt])
}

model ShortLink {
  id             String       @id @default(uuid())
  offerId        String?
  offer          Offer?       @relation(fields: [offerId], references: [id])
  code           String       @unique @db.VarChar(80)
  destinationUrl String
  clickCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  clickEvents    ClickEvent[]
}

model ClickEvent {
  id          String    @id @default(uuid())
  shortLinkId String?
  shortLink   ShortLink? @relation(fields: [shortLinkId], references: [id])
  offerId     String?
  offer       Offer?    @relation(fields: [offerId], references: [id])
  userAgent   String?
  ipHash      String?
  referer     String?
  clickedAt   DateTime  @default(now())
}

model IntegrationLog {
  id              String       @id @default(uuid())
  marketplaceId   String?
  marketplace     Marketplace? @relation(fields: [marketplaceId], references: [id])
  operation       String       @db.VarChar(120)
  status          String       @db.VarChar(50)
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  createdAt       DateTime     @default(now())
}

model PriceHistory {
  id                          String       @id @default(uuid())
  productId                   String       @map("product_id")
  product                     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplaceId               String?      @map("marketplace_id")
  marketplace                 Marketplace? @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)
  preco                       Decimal      @db.Decimal(12, 2)
  precoAnterior               Decimal?     @map("preco_anterior") @db.Decimal(12, 2)
  menorPreco30d               Decimal?     @map("menor_preco_30d") @db.Decimal(12, 2)
  mediaPreco30d               Decimal?     @map("media_preco_30d") @db.Decimal(12, 2)
  maiorPreco90d               Decimal?     @map("maior_preco_90d") @db.Decimal(12, 2)
  percentualDescontoInformado Decimal?     @map("percentual_desconto_informado") @db.Decimal(5, 2)
  percentualDescontoReal      Decimal?     @map("percentual_desconto_real") @db.Decimal(5, 2)
  statusDesconto              String?      @map("status_desconto") @db.VarChar(50)
  origem                      String?      @db.VarChar(120)
  dataColeta                  DateTime     @default(now()) @map("data_coleta")
  createdAt                   DateTime     @default(now()) @map("created_at")

  @@index([productId], map: "idx_price_history_product")
  @@index([dataColeta], map: "idx_price_history_data")
  @@index([marketplaceId], map: "idx_price_history_marketplace")
  @@map("price_history")
}

model OfferScore {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  scoreTotal     Decimal      @map("score_total") @db.Decimal(5, 2)
  scorePreco     Decimal?     @map("score_preco") @db.Decimal(5, 2)
  scoreDesconto  Decimal?     @map("score_desconto") @db.Decimal(5, 2)
  scoreAvaliacao Decimal?     @map("score_avaliacao") @db.Decimal(5, 2)
  scoreVendas    Decimal?     @map("score_vendas") @db.Decimal(5, 2)
  scoreComissao  Decimal?     @map("score_comissao") @db.Decimal(5, 2)
  scoreCupom     Decimal?     @map("score_cupom") @db.Decimal(5, 2)
  scoreFrete     Decimal?     @map("score_frete") @db.Decimal(5, 2)
  scoreReputacao Decimal?     @map("score_reputacao") @db.Decimal(5, 2)
  scoreSeo       Decimal?     @map("score_seo") @db.Decimal(5, 2)
  classificacao  String?      @db.VarChar(80)
  justificativa  String?
  recomendado    Boolean      @default(false)
  createdAt      DateTime     @default(now()) @map("created_at")
  opportunities  ProductOpportunity[]

  @@index([productId], map: "idx_offer_scores_product")
  @@index([scoreTotal(sort: Desc)], map: "idx_offer_scores_total")
  @@index([recomendado], map: "idx_offer_scores_recomendado")
  @@map("offer_scores")
}

model Coupon {
  id                 String           @id @default(uuid())
  marketplaceId      String           @map("marketplace_id")
  marketplace        Marketplace      @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  codigo             String           @db.VarChar(100)
  titulo             String?          @db.VarChar(180)
  descricao          String?
  percentualDesconto Decimal?         @map("percentual_desconto") @db.Decimal(5, 2)
  valorDesconto      Decimal?         @map("valor_desconto") @db.Decimal(12, 2)
  valorMinimo        Decimal?         @map("valor_minimo") @db.Decimal(12, 2)
  dataInicio         DateTime?        @map("data_inicio")
  dataFim            DateTime?        @map("data_fim")
  status             Boolean          @default(true)
  origem             String?          @db.VarChar(120)
  urlOrigem          String?          @map("url_origem")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  products           CouponProduct[]
  categories         CouponCategory[]

  @@unique([marketplaceId, codigo], map: "coupons_marketplace_codigo_key")
  @@index([marketplaceId], map: "idx_coupons_marketplace")
  @@index([codigo], map: "idx_coupons_codigo")
  @@index([dataInicio, dataFim], map: "idx_coupons_validade")
  @@map("coupons")
}

model CouponProduct {
  id        String   @id @default(uuid())
  couponId  String   @map("coupon_id")
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([couponId, productId], map: "coupon_products_coupon_product_key")
  @@index([productId], map: "idx_coupon_products_product")
  @@map("coupon_products")
}

model CouponCategory {
  id         String   @id @default(uuid())
  couponId   String   @map("coupon_id")
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([couponId, categoryId], map: "coupon_categories_coupon_category_key")
  @@index([categoryId], map: "idx_coupon_categories_category")
  @@map("coupon_categories")
}

model SeoPage {
  id                         String       @id @default(uuid())
  productId                  String?      @map("product_id")
  product                    Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  categoryId                 String?      @map("category_id")
  category                   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  marketplaceId              String?      @map("marketplace_id")
  marketplace                Marketplace? @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)
  tipo                       String       @db.VarChar(80)
  slug                       String       @unique
  tituloSeo                  String       @map("titulo_seo")
  metaDescription            String?      @map("meta_description")
  h1                         String?
  conteudo                   String?
  faq                        Json?
  schemaJson                 Json?        @map("schema_json")
  palavraChavePrincipal      String?      @map("palavra_chave_principal")
  palavrasChaveSecundarias   String[]     @default([]) @map("palavras_chave_secundarias")
  status                     String       @default("rascunho") @db.VarChar(50)
  publishedAt                DateTime?    @map("published_at")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")
  deletedAt                  DateTime?    @map("deleted_at")

  @@index([slug], map: "idx_seo_pages_slug")
  @@index([status], map: "idx_seo_pages_status")
  @@index([tipo], map: "idx_seo_pages_tipo")
  @@map("seo_pages")
}

model SeoKeyword {
  id           String   @id @default(uuid())
  termo        String
  volumeBusca  Int?     @map("volume_busca")
  dificuldade  Decimal? @db.Decimal(5, 2)
  intencao     String?  @db.VarChar(80)
  categoria    String?  @db.VarChar(120)
  origem       String?  @db.VarChar(120)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([termo], map: "idx_seo_keywords_termo")
  @@index([intencao], map: "idx_seo_keywords_intencao")
  @@map("seo_keywords")
}

model ProductOpportunity {
  id          String      @id @default(uuid())
  productId   String      @map("product_id")
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  scoreId     String?     @map("score_id")
  score       OfferScore? @relation(fields: [scoreId], references: [id], onDelete: SetNull)
  tipo        String?     @db.VarChar(80)
  titulo      String?
  descricao   String?
  prioridade  String?     @db.VarChar(40)
  status      String      @default("aberta") @db.VarChar(40)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([productId], map: "idx_product_opportunities_product")
  @@index([scoreId], map: "idx_product_opportunities_score")
  @@index([status], map: "idx_product_opportunities_status")
  @@map("product_opportunities")
}

model PublicationSchedule {
  id              String         @id @default(uuid())
  productId       String?        @map("product_id")
  product         Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  offerId         String?        @map("offer_id")
  offer           Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  scheduledPostId String?        @unique @map("scheduled_post_id")
  scheduledPost   ScheduledPost? @relation(fields: [scheduledPostId], references: [id], onDelete: SetNull)
  creativeAssetId String?        @map("creative_asset_id")
  creativeAsset   CreativeAsset? @relation(fields: [creativeAssetId], references: [id], onDelete: SetNull)
  channel         String         @db.VarChar(60)
  message         String?
  scheduledAt     DateTime?      @map("scheduled_at")
  publishedAt     DateTime?      @map("published_at")
  status          String         @default("SCHEDULED") @db.VarChar(40)
  attempts        Int            @default(0)
  errorMessage    String?        @map("error_message")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([productId], map: "idx_publication_schedule_product")
  @@index([offerId], map: "idx_publication_schedule_offer")
  @@index([channel], map: "idx_publication_schedule_channel")
  @@index([status, scheduledAt], map: "idx_publication_schedule_status_time")
  @@map("publication_schedule")
}

model CreativeAsset {
  id           String                @id @default(uuid())
  productId    String?               @map("product_id")
  product      Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  type         String                @db.VarChar(50)
  fileUrl      String?               @map("file_url")
  prompt       String?
  status       String                @default("DRAFT") @db.VarChar(30)
  channel      String?               @db.VarChar(60)
  metadata     Json?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  schedules    PublicationSchedule[]

  @@index([productId], map: "idx_creative_assets_product")
  @@index([status], map: "idx_creative_assets_status")
  @@map("creative_assets")
}
