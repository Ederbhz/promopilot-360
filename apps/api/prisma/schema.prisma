generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum MarketplaceKey {
  AWIN
  SHOPEE
  MERCADO_LIVRE
  MAGALU
  MANUAL
}

enum IntegrationType {
  API
  FEED
  MANUAL
  ASSISTED
}

enum OfferStatus {
  DRAFT
  VALIDATING
  VALID
  INVALID
  EXPIRED
  AFFILIATE_LINK_MISSING
  SCHEDULED
  PUBLISHED
  FAILED
  PAUSED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum Channel {
  TELEGRAM
  WHATSAPP
  INSTAGRAM
  MANUAL
}

enum ScheduledPostStatus {
  SCHEDULED
  READY_TO_SEND
  PUBLISHED
  FAILED
  CANCELED
}

enum WhatsAppProvider {
  WPPCONNECT
  CLOUD_API
  WASSENGER
  WEBHOOK
  ASSISTED
}

enum WhatsAppConnectionStatus {
  CONNECTED
  DISCONNECTED
  WAITING_QR_CODE
  EXPIRED
  AUTH_ERROR
  ERROR
  WARNING
}

model User {
  id                String             @id @default(uuid())
  name              String             @db.VarChar(150)
  email             String             @unique @db.VarChar(180)
  passwordHash      String
  role              Role               @default(ADMIN)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  generatedContents GeneratedContent[]
  auditLogs         AuditLog[]
}

model Marketplace {
  id               String             @id @default(uuid())
  name             String             @db.VarChar(100)
  key              MarketplaceKey     @unique
  integrationType  IntegrationType
  baseUrl          String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  affiliateAccounts AffiliateAccount[]
  products         Product[]
  offers           Offer[]
  campaigns        Campaign[]
  integrationLogs  IntegrationLog[]
}

model AffiliateAccount {
  id                   String      @id @default(uuid())
  marketplaceId        String
  marketplace          Marketplace @relation(fields: [marketplaceId], references: [id])
  name                 String      @db.VarChar(120)
  accountIdentifier    String?     @db.VarChar(180)
  affiliateTag         String?     @db.VarChar(180)
  encryptedCredentials Json?
  config               Json?
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?
}

model Product {
  id                String             @id @default(uuid())
  marketplaceId     String
  marketplace       Marketplace        @relation(fields: [marketplaceId], references: [id])
  categoryId        String?
  categoryRef       Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId           String?
  brandRef          Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  externalId        String?            @db.VarChar(180)
  title             String
  description       String?
  imageUrl          String?
  productUrl        String
  brand             String?            @db.VarChar(120)
  category          String?            @db.VarChar(120)
  rating            Decimal?           @db.Decimal(3, 2)
  reviewCount       Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  offers            Offer[]
  generatedContents GeneratedContent[]

  @@index([marketplaceId])
  @@index([categoryId])
  @@index([brandId])
  @@index([externalId])
  @@index([deletedAt])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(140)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  products    Product[]

  @@index([isActive])
  @@index([deletedAt])
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(140)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  products    Product[]

  @@index([isActive])
  @@index([deletedAt])
}

model Offer {
  id                  String      @id @default(uuid())
  productId           String
  product             Product     @relation(fields: [productId], references: [id])
  marketplaceId       String
  marketplace         Marketplace @relation(fields: [marketplaceId], references: [id])
  originalUrl         String
  affiliateUrl        String?
  currentPrice        Decimal?    @db.Decimal(12, 2)
  oldPrice            Decimal?    @db.Decimal(12, 2)
  discountPercent     Decimal?    @db.Decimal(5, 2)
  couponCode          String?     @db.VarChar(120)
  couponDescription   String?
  freeShipping        Boolean?
  estimatedCommission Decimal?    @db.Decimal(12, 2)
  commissionPercent   Decimal?    @db.Decimal(5, 2)
  score               Decimal?    @db.Decimal(5, 2)
  status              OfferStatus @default(DRAFT)
  validUntil          DateTime?
  metadata            Json?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  scheduledPosts      ScheduledPost[]
  publishLogs         PublishLog[]
  shortLinks          ShortLink[]
  clickEvents         ClickEvent[]
  generatedContents   GeneratedContent[]

  @@index([marketplaceId])
  @@index([status])
  @@index([createdAt])
}

model GeneratedContent {
  id          String    @id @default(uuid())
  offerId     String?
  offer       Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  channel     Channel   @default(WHATSAPP)
  title       String    @db.VarChar(180)
  prompt      String?
  content     String
  tone        String?   @db.VarChar(80)
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([offerId])
  @@index([productId])
  @@index([createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String   @db.VarChar(80)
  entityId  String?
  action    String   @db.VarChar(80)
  before    Json?
  after     Json?
  metadata  Json?
  ipHash    String?  @db.VarChar(120)
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model MessageTemplate {
  id         String     @id @default(uuid())
  name       String     @db.VarChar(120)
  channel    Channel
  content    String
  isDefault  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  campaigns  Campaign[]
}

model Campaign {
  id                    String         @id @default(uuid())
  name                  String         @db.VarChar(150)
  marketplaceId         String?
  marketplace           Marketplace?   @relation(fields: [marketplaceId], references: [id])
  templateId            String?
  template              MessageTemplate? @relation(fields: [templateId], references: [id])
  channel               Channel
  status                CampaignStatus @default(PAUSED)
  startTime             String?
  endTime               String?
  intervalMinutes       Int            @default(30)
  dailyLimit            Int            @default(30)
  requireManualApproval Boolean        @default(true)
  allowRepost           Boolean        @default(false)
  minHoursToRepost      Int            @default(72)
  config                Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  scheduledPosts        ScheduledPost[]
  whatsappGroups        CampaignWhatsAppGroup[]
  messageSendLogs       MessageSendLog[]
}

model ScheduledPost {
  id            String              @id @default(uuid())
  campaignId    String?
  campaign      Campaign?           @relation(fields: [campaignId], references: [id])
  offerId       String
  offer         Offer               @relation(fields: [offerId], references: [id])
  whatsappGroupId String?
  whatsappGroup WhatsAppGroup?      @relation(fields: [whatsappGroupId], references: [id])
  channel       Channel
  message       String
  scheduledAt   DateTime
  publishedAt   DateTime?
  status        ScheduledPostStatus @default(SCHEDULED)
  errorMessage  String?
  retryCount    Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  publishLogs   PublishLog[]
  messageSendLogs MessageSendLog[]

  @@index([status, scheduledAt])
  @@index([whatsappGroupId])
}

model WhatsAppConnection {
  id                   String                  @id @default(uuid())
  name                 String                  @db.VarChar(120)
  sessionName          String?                 @unique @db.VarChar(120)
  phoneNumber          String?                 @db.VarChar(40)
  provider             WhatsAppProvider        @default(WPPCONNECT)
  status               WhatsAppConnectionStatus @default(DISCONNECTED)
  phoneNumberId        String?                 @db.VarChar(120)
  qrCode               String?
  lastConnectedAt      DateTime?
  lastError            String?
  consecutiveFailures  Int                     @default(0)
  dailySentCount       Int                     @default(0)
  dailyLimit           Int                     @default(100)
  dailyWindowStartedAt DateTime?
  minIntervalSeconds   Int                     @default(60)
  lastSentAt           DateTime?
  encryptedCredentials Json?
  config               Json?
  isActive             Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  groups               WhatsAppGroup[]
  messageSendLogs      MessageSendLog[]
}

model WhatsAppGroup {
  id           String                  @id @default(uuid())
  connectionId String
  connection   WhatsAppConnection      @relation(fields: [connectionId], references: [id])
  name         String                  @db.VarChar(160)
  externalId   String                  @db.VarChar(220)
  description  String?
  category     String?                 @db.VarChar(120)
  type         String                  @default("GROUP") @db.VarChar(40)
  isActive     Boolean                 @default(true)
  minIntervalSeconds Int               @default(60)
  dailyLimit   Int                     @default(100)
  dailySentCount Int                   @default(0)
  dailyWindowStartedAt DateTime?
  lastSentAt   DateTime?
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  campaigns    CampaignWhatsAppGroup[]
  scheduledPosts ScheduledPost[]
  messageSendLogs MessageSendLog[]

  @@index([connectionId])
  @@unique([connectionId, externalId])
}

model CampaignWhatsAppGroup {
  campaignId String
  campaign   Campaign      @relation(fields: [campaignId], references: [id])
  groupId    String
  group      WhatsAppGroup @relation(fields: [groupId], references: [id])
  createdAt  DateTime      @default(now())

  @@id([campaignId, groupId])
  @@index([groupId])
}

model PublishLog {
  id              String         @id @default(uuid())
  scheduledPostId String?
  scheduledPost   ScheduledPost? @relation(fields: [scheduledPostId], references: [id])
  offerId         String?
  offer           Offer?         @relation(fields: [offerId], references: [id])
  channel         Channel
  status          String         @db.VarChar(50)
  providerResponse Json?
  errorMessage    String?
  createdAt       DateTime       @default(now())
}

model MessageSendLog {
  id                  String              @id @default(uuid())
  scheduledPostId     String?
  scheduledPost       ScheduledPost?      @relation(fields: [scheduledPostId], references: [id])
  campaignId          String?
  campaign            Campaign?           @relation(fields: [campaignId], references: [id])
  whatsappGroupId     String?
  whatsappGroup       WhatsAppGroup?      @relation(fields: [whatsappGroupId], references: [id])
  whatsappConnectionId String?
  whatsappConnection  WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id])
  message             String
  scheduledAt         DateTime?
  sentAt              DateTime?
  status              String              @db.VarChar(40)
  errorMessage        String?
  attempts            Int                 @default(0)
  providerResponse    Json?
  userResponsible     String?             @db.VarChar(180)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([campaignId])
  @@index([whatsappGroupId])
  @@index([whatsappConnectionId])
  @@index([status, scheduledAt])
}

model ShortLink {
  id             String       @id @default(uuid())
  offerId        String?
  offer          Offer?       @relation(fields: [offerId], references: [id])
  code           String       @unique @db.VarChar(80)
  destinationUrl String
  clickCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  clickEvents    ClickEvent[]
}

model ClickEvent {
  id          String    @id @default(uuid())
  shortLinkId String?
  shortLink   ShortLink? @relation(fields: [shortLinkId], references: [id])
  offerId     String?
  offer       Offer?    @relation(fields: [offerId], references: [id])
  userAgent   String?
  ipHash      String?
  referer     String?
  clickedAt   DateTime  @default(now())
}

model IntegrationLog {
  id              String       @id @default(uuid())
  marketplaceId   String?
  marketplace     Marketplace? @relation(fields: [marketplaceId], references: [id])
  operation       String       @db.VarChar(120)
  status          String       @db.VarChar(50)
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  createdAt       DateTime     @default(now())
}
